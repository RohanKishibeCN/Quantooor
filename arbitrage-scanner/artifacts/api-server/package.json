{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "test": "node --import tsx --test src/lib/__tests__/dexdexQuoteEngine.test.ts src/lib/__tests__/dexdexOpportunityMath.test.ts",
    "smoke:dexdex": "tsx ./src/scripts/dexdexSmoke.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "ccxt": "^4.5.44",
    "ccxws": "^0.47.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^16.6.1",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "pino": "^9",
    "pino-http": "^10",
    "protobufjs": "^8.0.0",
    "viem": "^2.47.6",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "tsx": "catalog:",
    "thread-stream": "3.1.0"
  }
}
