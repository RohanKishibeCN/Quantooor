{
  "name": "minara-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.20.2"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/**/__tests__/*.test.ts",
    "accounts:encrypt": "tsx src/scripts/accounts-encrypt.ts"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "viem": "^2.47.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
